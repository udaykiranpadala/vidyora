# Server
PORT=5000

# MongoDB Atlas connection string (get this from your Atlas dashboard)
MONGO_URI=your_mongodb_atlas_connection_string_here

# JWT secret for organizer login sessions (any long random string)
JWT_SECRET=change_this_to_a_long_random_secret_string

# Email (for sending OTP) - using Gmail as example
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your_gmail_app_password

# Resend API Key (for transactional emails in production)
RESEND_API_KEY=your_resend_api_key_here

# Judge0 API (for running code submissions)
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your_rapidapi_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Google OAuth (Web client ID from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
